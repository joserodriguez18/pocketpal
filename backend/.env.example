# ══════════════════════════════════════════════════════════════════════════════
# PocketPal Finance — Variables de entorno
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Llena cada variable con tus valores reales.
#   3. NUNCA subas .env a git (ya está en .gitignore).
#
# DEPLOY:
#   Cambia las URLs (FRONTEND_URL, GOOGLE_CALLBACK_URL, CORS_ORIGIN) al dominio
#   real de producción. No se requiere tocar ningún otro archivo del código.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos MySQL ───────────────────────────────────────────────────────
# Desarrollo local:
#   DB_HOST=localhost
#   DB_PORT=3306
# Producción en la nube (ej: Aiven, PlanetScale, RDS):
#   DB_HOST=mysql-abc.aivencloud.com
#   DB_PORT=12345

DB_HOST=localhost
DB_PORT=3306
DB_NAME=pocketpal
DB_USER=root
DB_PASSWORD=

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera un secreto aleatorio seguro:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
# Modelo a usar. gpt-4o es el recomendado para function calling.
# Alternativa más económica: gpt-4o-mini
OPENAI_MODEL=gpt-4o

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Crear credenciales en: https://console.cloud.google.com/apis/credentials
# Tipo: "ID de cliente OAuth" → "Aplicación web"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL de callback de OAuth — DEBE coincidir exactamente con la configurada
# en Google Cloud Console → "URIs de redireccionamiento autorizados".
#
# Desarrollo:  http://localhost:3000/api/auth/google/callback
# Producción:  https://tudominio.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── CORS ─────────────────────────────────────────────────────────────────────
# Orígenes permitidos para peticiones cross-origin (separados por coma).
# Si el frontend y el backend corren en el mismo servidor, poner la URL del servidor.
#
# Desarrollo:  http://localhost:3000,http://127.0.0.1:3000
# Producción:  https://tudominio.com
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# ── URLs del frontend ─────────────────────────────────────────────────────────
# URL base del frontend — usada por authController.js para construir los redirects
# de OAuth y los mensajes de error.
#
# Desarrollo:  http://localhost:3000
# Producción:  https://tudominio.com
FRONTEND_URL=http://localhost:3000
